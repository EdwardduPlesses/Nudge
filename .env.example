# Whop (required for production)
WHOP_API_KEY=
NEXT_PUBLIC_WHOP_APP_ID=

# Optional: set to 1 locally to enforce real Whop auth and gates
# NUDGE_STRICT_WHOP=1

# Supabase (optional) — when set, budget data syncs to Postgres
# Run supabase/migrations/20250430120000_nudge_budget.sql in the SQL editor or via CLI.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Standalone OAuth (added 2026-05-26) — required for /app standalone sign-in
# Register WHOP_OAUTH_REDIRECT_URI in your Whop app dashboard as an allowed callback.
# Whop uses PKCE; no client secret is needed.
WHOP_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/whop/callback
# 64+ random hex chars: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
NUDGE_SESSION_SECRET=
